 depende do contexto específico]"},{"role":"user","content":"Não seria declaração de limpeza de área?"}],"model":"auto"}},"response":{"status":200,"statusText":"OK","headers":{"access-control-allow-origin":"http://localhost:3000","alt-svc":"h3=\":443\"; ma=86400","cache-control":"no-cache, no-transform","cf-cache-status":"DYNAMIC","cf-ray":"9cff6bdb1f45db39-GRU","connection":"close","content-type":"application/x-ndjson; charset=utf-8","date":"Wed, 18 Feb 2026 17:59:58 GMT","rndr-id":"18ec91d0-b1a6-4fda","server":"cloudflare","transfer-encoding":"chunked","vary":"Origin","x-powered-by":"Express","x-render-origin-server":"Render","x-request-id":"9dfa151a-2c97-4a0e-858c-d834212fabc9"},"body":"[Streaming response - not captured]"},"duration":897,"error":null}
