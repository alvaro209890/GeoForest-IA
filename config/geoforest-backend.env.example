NODE_ENV=production
PORT=3001
LOCAL_DATA_ROOT=/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados/GeoForest

GROQ_API_KEY=
GEMINI_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

SEMA_WMS_BASE_URL=https://geo.sema.mt.gov.br/geoserver/ows
SEMA_WMS_AUTHKEY=541085de-9a2e-454e-bdba-eb3d57a2f492

PRODES_WFS_URL=https://terrabrasilis.dpi.inpe.br/geoserver/ows
PRODES_LAYER=prodes-legal-amz:yearly_deforestation
PRODES_YEAR_FIELD=year

SFB_WFS_URL=https://geo.sema.mt.gov.br/geoserver/wfs
SFB_RIVER_LAYER=Geoportal:SFB_HIDRO_TRECHO_DRENAGEM
SFB_WFS_AUTHKEY=541085de-9a2e-454e-bdba-eb3d57a2f492

# --- CBERS / GeoServer / WMS ---
# Os valores abaixo sao os DEFAULTS embutidos no codigo (servidor do WMS). So precisam ser
# definidos aqui para sobrescrever em outro host. Rode scripts/cbers-doctor.sh para validar.
# Acervo permanente dos GeoTIFFs (HD de 2 TB):
CBERS_ARCHIVE_ROOT=/media/server/HD Backup/RASTER/CBERS_4A
# GeoServer local (REST usada para publicacao automatica) e WMS publico:
GEOSERVER_BASE_URL=http://127.0.0.1:8081/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver
GEOSERVER_WORKSPACE=cbers
GEOSERVER_DATA_DIR=/home/server/geoserver_data
GEOSERVER_EXTERNAL_CBRS_ROOT=/home/server/.local/geoserver-work/data_dir/external/cbers
GEOSERVER_PUBLIC_WMS_BASE=https://wms.cursar.space/geoserver/cbers/wms
GEOSERVER_RASTER_STYLE=raster
# Realce de contraste 8 bits da imagem gerada:
#   global  (padrao) clareia/contrasta SEM mudar o balanco de cor (preserva o 342 verde)
#   perband contraste maximo, mas muda a cor (falsa-cor magenta/verde)
#   minmax  comportamento antigo (min..max absoluto, escuro)
# Aumente o sigma para um realce mais suave (corta menos a cauda clara).
CBERS_STRETCH_MODE=global
CBERS_STRETCH_SIGMA=2.5
CBERS_STRETCH_APPROX=1
# Piramides de overview do GeoTIFF publicado (zoom-out mais suave no WMS):
CBERS_OVERVIEW_RESAMPLING=average
# Robustez da publicacao quando o GeoServer reinicia (deploy):
GEOSERVER_PUBLISH_RETRIES=4
GEOSERVER_PUBLISH_RETRY_DELAY_MS=4000
GEOSERVER_READY_TIMEOUT_MS=60000
