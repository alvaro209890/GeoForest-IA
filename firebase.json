{
  "hosting": [
    {
      "site": "ia-florestal",
      "public": "dist/public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "redirects": [
        {
          "source": "/api/:path*",
          "destination": "https://geoforest-api.cursar.space/api/:path",
          "type": 302
        }
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "site": "geoforest-admin",
      "public": "dist/admin",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "redirects": [
        {
          "source": "/api/:path*",
          "destination": "https://geoforest-api.cursar.space/api/:path",
          "type": 302
        }
      ],
      "rewrites": [{ "source": "**", "destination": "/admin.html" }]
    }
  ]
}
